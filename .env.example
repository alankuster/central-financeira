# =====================================================
# CENTRAL FINANCEIRA FAMILIAR — Configuração
# Copie este arquivo para .env e preencha os valores
# =====================================================

# ── SUPABASE ──────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
REACT_APP_SUPABASE_URL=https://SEU_PROJETO.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── ANTHROPIC (IA Consultora) ─────────────────────
# Encontre em: console.anthropic.com → API Keys
# ATENÇÃO: Em produção, use um backend para proteger a chave!
REACT_APP_ANTHROPIC_API_KEY=sk-ant-sua_chave_aqui
